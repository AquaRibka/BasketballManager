generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlayerPosition {
  PG
  SG
  SF
  PF
  C
}

enum MatchStatus {
  SCHEDULED
  COMPLETED
}

model Team {
  id         String  @id @default(cuid())
  name       String  @db.VarChar(120)
  city       String  @db.VarChar(120)
  shortName  String  @unique @db.VarChar(10)
  rating     Int     @default(60)
  players    Player[]
  homeMatches Match[] @relation("HomeTeamMatches")
  awayMatches Match[] @relation("AwayTeamMatches")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Player {
  id          String         @id @default(cuid())
  name        String         @db.VarChar(120)
  age         Int
  position    PlayerPosition
  shooting    Int
  passing     Int
  defense     Int
  rebounding  Int
  athleticism Int
  potential   Int
  overall     Int
  teamId      String?
  team        Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([teamId])
}

model Match {
  id          String      @id @default(cuid())
  seasonId    String?
  round       Int?
  homeTeamId  String
  awayTeamId  String
  homeTeam    Team        @relation("HomeTeamMatches", fields: [homeTeamId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  awayTeam    Team        @relation("AwayTeamMatches", fields: [awayTeamId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  status      MatchStatus @default(SCHEDULED)
  homeScore   Int?
  awayScore   Int?
  winnerTeamId String?
  standingsUpdateRequired Boolean @default(false)
  playedAt    DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([seasonId, round])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlayerPosition {
  PG
  SG
  SF
  PF
  C
}

enum MatchStatus {
  SCHEDULED
  COMPLETED
}

enum SeasonStatus {
  IN_PROGRESS
  COMPLETED
}

model Season {
  id           String       @id @default(cuid())
  name         String       @db.VarChar(120)
  year         Int
  status       SeasonStatus @default(IN_PROGRESS)
  currentRound Int          @default(1)
  startedAt    DateTime     @default(now())
  finishedAt   DateTime?
  matches      Match[]
  standings    Standing[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([status])
  @@index([year])
}

model Team {
  id               String            @id @default(cuid())
  name             String            @db.VarChar(120)
  city             String            @db.VarChar(120)
  shortName        String            @unique @db.VarChar(10)
  rating           Int               @default(60)
  players          Player[]
  homeMatches      Match[]           @relation("HomeTeamMatches")
  awayMatches      Match[]           @relation("AwayTeamMatches")
  standings        Standing[]
  matchPlayerStats MatchPlayerStat[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

model Player {
  id               String            @id @default(cuid())
  name             String            @db.VarChar(120)
  age              Int
  position         PlayerPosition
  shooting         Int
  passing          Int
  defense          Int
  rebounding       Int
  athleticism      Int
  potential        Int
  overall          Int
  teamId           String?
  team             Team?             @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  matchPlayerStats MatchPlayerStat[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([teamId])
}

model Match {
  id                      String            @id @default(cuid())
  seasonId                String?
  season                  Season?           @relation(fields: [seasonId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  round                   Int?
  date                    DateTime?
  homeTeamId              String
  awayTeamId              String
  homeTeam                Team              @relation("HomeTeamMatches", fields: [homeTeamId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  awayTeam                Team              @relation("AwayTeamMatches", fields: [awayTeamId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  status                  MatchStatus       @default(SCHEDULED)
  homeScore               Int?
  awayScore               Int?
  winnerTeamId            String?
  standingsUpdateRequired Boolean           @default(false)
  playerStats             MatchPlayerStat[]
  playedAt                DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@index([seasonId, round])
  @@index([date])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model MatchPlayerStat {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  points    Int      @default(0)
  rebounds  Int      @default(0)
  assists   Int      @default(0)
  steals    Int      @default(0)
  blocks    Int      @default(0)
  minutes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
  @@index([teamId])
}

model Standing {
  id            String   @id @default(cuid())
  seasonId      String
  season        Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teamId        String
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  position      Int      @default(0)
  wins          Int      @default(0)
  losses        Int      @default(0)
  pointsFor     Int      @default(0)
  pointsAgainst Int      @default(0)
  pointDiff     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([seasonId, teamId])
  @@index([seasonId])
  @@index([seasonId, position])
  @@index([teamId])
}

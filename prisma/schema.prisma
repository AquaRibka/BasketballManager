generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum PlayerPosition {
  PG
  SG
  SF
  PF
  C
}

enum PlayerDominantHand {
  LEFT
  RIGHT
  AMBIDEXTROUS
}

enum PlayerBodyType {
  SLIM
  ATHLETIC
  STRONG
  HEAVY
}

enum PlayerInjurySeverity {
  MINOR
  MODERATE
  MAJOR
  SEVERE
}

enum PlayerInjuryStatus {
  ACTIVE
  RECOVERING
  RECOVERED
}

enum PlayerDevelopmentFocus {
  BALANCED
  SCORING
  PLAYMAKING
  DEFENSE
  ATHLETICISM
  REBOUNDING
}

enum PlayerCareerStatus {
  ACTIVE
  FORMER
  FREE_AGENT
}

enum MatchStatus {
  SCHEDULED
  COMPLETED
}

enum SeasonStatus {
  IN_PROGRESS
  COMPLETED
}

model Season {
  id                  String                @id @default(cuid())
  name                String                @db.VarChar(120)
  year                Int
  status              SeasonStatus          @default(IN_PROGRESS)
  currentRound        Int                   @default(1)
  startedAt           DateTime              @default(now())
  finishedAt          DateTime?
  careerSaves         CareerSave[]
  matches             Match[]
  standings           Standing[]
  playerCareerHistory PlayerCareerHistory[]
  playerSeasonStats   PlayerSeasonStat[]
  playerAwards        PlayerAward[]
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  @@index([status])
  @@index([year])
}

model Team {
  id                   String                @id @default(cuid())
  name                 String                @db.VarChar(120)
  city                 String                @db.VarChar(120)
  shortName            String                @unique @db.VarChar(10)
  rating               Int                   @default(60)
  careerSaves          CareerSave[]
  players              Player[]
  homeMatches          Match[]               @relation("HomeTeamMatches")
  awayMatches          Match[]               @relation("AwayTeamMatches")
  standings            Standing[]
  matchPlayerStats     MatchPlayerStat[]
  careerHistoryEntries PlayerCareerHistory[]
  playerSeasonStats    PlayerSeasonStat[]
  playerAwards         PlayerAward[]
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
}

model Player {
  id                  String                     @id @default(cuid())
  name                String                     @db.VarChar(120)
  age                 Int
  dateOfBirth         DateTime?
  dominantHand        PlayerDominantHand?
  position            PlayerPosition
  secondaryPositions  PlayerPosition[]           @default([])
  shooting            Int
  passing             Int
  defense             Int
  rebounding          Int
  athleticism         Int
  potential           Int
  overall             Int
  teamId              String?
  team                Team?                      @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  technicalAttributes PlayerTechnicalAttributes?
  physicalProfile     PlayerPhysicalProfile?
  mentalAttributes    PlayerMentalAttributes?
  tacticalAttributes  PlayerTacticalAttributes?
  hiddenAttributes    PlayerHiddenAttributes?
  healthProfile       PlayerHealthProfile?
  potentialProfile    PlayerPotentialProfile?
  reputationProfile   PlayerReputationProfile?
  careerHistory       PlayerCareerHistory[]
  seasonStats         PlayerSeasonStat[]
  awards              PlayerAward[]
  injuryHistory       PlayerInjuryHistory[]
  matchPlayerStats    MatchPlayerStat[]
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt

  @@index([teamId])
}

model PlayerTechnicalAttributes {
  id               String   @id @default(cuid())
  playerId         String   @unique
  player           Player   @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  shooting         Int
  passing          Int
  defense          Int
  rebounding       Int
  ballHandling     Int
  dribbling        Int
  midRangeShot     Int
  threePointShot   Int
  freeThrow        Int
  rimFinishing     Int
  dunking          Int
  postMoves        Int
  perimeterDefense Int
  interiorDefense  Int
  offensiveRebound Int
  defensiveRebound Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model PlayerPhysicalProfile {
  id              String          @id @default(cuid())
  playerId        String          @unique
  player          Player          @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  heightCm        Int
  weightKg        Int
  wingspanCm      Int?
  bodyType        PlayerBodyType?
  standingReachCm Int?
  speed           Int
  acceleration    Int
  strength        Int
  explosiveness   Int
  agility         Int
  balance         Int
  coordination    Int
  reaction        Int
  vertical        Int
  stamina         Int
  endurance       Int
  recovery        Int
  durability      Int
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model PlayerMentalAttributes {
  id              String   @id @default(cuid())
  playerId        String   @unique
  player          Player   @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  confidence      Int
  selfControl     Int
  concentration   Int
  composure       Int
  determination   Int
  workEthic       Int
  professionalism Int
  leadership      Int
  aggressiveness  Int
  competitiveness Int
  teamwork        Int
  teamOrientation Int
  loyalty         Int
  ego             Int
  clutchFactor    Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model PlayerTacticalAttributes {
  id                   String   @id @default(cuid())
  playerId             String   @unique
  player               Player   @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  basketballIQ         Int
  courtVision          Int
  defenseReading       Int
  offenseReading       Int
  decisionMaking       Int
  shotSelection        Int
  offBallMovement      Int
  spacing              Int
  pickAndRollOffense   Int
  pickAndRollDefense   Int
  helpDefense          Int
  discipline           Int
  helpDefenseAwareness Int
  offBallAwareness     Int
  pickAndRollRead      Int
  spacingSense         Int
  playDiscipline       Int
  foulDiscipline       Int
  transitionInstincts  Int
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model PlayerHiddenAttributes {
  id                String   @id @default(cuid())
  playerId          String   @unique
  player            Player   @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  consistency       Int
  injuryProneness   Int
  importantMatches  Int
  wantsToLeave      Int
  declineResistance Int
  adaptability      Int
  discipline        Int
  ambition          Int
  resilience        Int
  pressureHandling  Int
  setbackResponse   Int
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model PlayerHealthProfile {
  id                  String   @id @default(cuid())
  playerId            String   @unique
  player              Player   @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  overallCondition    Int
  fatigue             Int
  postInjuryCondition Int
  durability          Int
  recoveryRate        Int
  injuryRisk          Int
  fatigueBase         Int
  matchFitness        Int
  painTolerance       Int
  medicalOutlook      Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PlayerInjuryHistory {
  id               String               @id @default(cuid())
  playerId         String
  player           Player               @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  title            String               @db.VarChar(120)
  bodyPart         String               @db.VarChar(80)
  severity         PlayerInjurySeverity
  status           PlayerInjuryStatus   @default(RECOVERED)
  occurredAt       DateTime
  expectedReturnAt DateTime?
  returnedAt       DateTime?
  gamesMissed      Int                  @default(0)
  notes            String?              @db.VarChar(500)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([playerId, occurredAt])
}

model PlayerPotentialProfile {
  id               String                 @id @default(cuid())
  playerId         String                 @unique
  player           Player                 @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  potential        Int
  potentialAbility Int
  currentAbility   Int
  growthRate       Int
  developmentFocus PlayerDevelopmentFocus @default(BALANCED)
  peakStartAge     Int
  peakEndAge       Int
  declineStartAge  Int
  learningAbility  Int
  peakWindowStart  Int
  peakWindowEnd    Int
  ceilingTier      Int
  readiness        Int
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
}

model PlayerCareerHistory {
  id             String             @id @default(cuid())
  playerId       String
  player         Player             @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  seasonId       String?
  season         Season?            @relation(fields: [seasonId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  seasonLabel    String             @db.VarChar(40)
  teamId         String?
  team           Team?              @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  league         String             @db.VarChar(80)
  role           String             @db.VarChar(80)
  jerseyNumber   Int?
  status         PlayerCareerStatus @default(ACTIVE)
  transferDate   DateTime?
  transferReason String?            @db.VarChar(120)
  achievements   String[]           @default([])
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([playerId, seasonLabel])
  @@index([playerId, transferDate])
  @@index([teamId])
  @@index([seasonId])
}

model PlayerSeasonStat {
  id               String   @id @default(cuid())
  playerId         String
  player           Player   @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  seasonId         String?
  season           Season?  @relation(fields: [seasonId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  seasonLabel      String   @db.VarChar(40)
  teamId           String?
  team             Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  league           String   @db.VarChar(80)
  gamesPlayed      Int
  gamesStarted     Int
  minutesPerGame   Float
  pointsPerGame    Float
  reboundsPerGame  Float
  assistsPerGame   Float
  stealsPerGame    Float
  blocksPerGame    Float
  turnoversPerGame Float
  foulsPerGame     Float
  fgPct            Float
  threePct         Float
  ftPct            Float
  efficiencyRating Float
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([playerId, seasonLabel])
  @@index([seasonId])
  @@index([teamId])
}

model PlayerAward {
  id          String   @id @default(cuid())
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  seasonId    String?
  season      Season?  @relation(fields: [seasonId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  seasonLabel String   @db.VarChar(40)
  awardType   String   @db.VarChar(80)
  league      String   @db.VarChar(80)
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  description String?  @db.VarChar(240)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([playerId, seasonLabel])
  @@index([seasonId])
  @@index([teamId])
}

model PlayerReputationProfile {
  id                      String   @id @default(cuid())
  playerId                String   @unique
  player                  Player   @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  reputation              Int
  hiddenReputation        Int
  leagueReputation        Int
  internationalReputation Int
  starPower               Int
  fanAppeal               Int
  mediaHandling           Int
  mediaAppeal             Int
  agentInfluence          Int
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model Match {
  id                      String            @id @default(cuid())
  seasonId                String?
  season                  Season?           @relation(fields: [seasonId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  round                   Int?
  date                    DateTime?
  homeTeamId              String
  awayTeamId              String
  homeTeam                Team              @relation("HomeTeamMatches", fields: [homeTeamId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  awayTeam                Team              @relation("AwayTeamMatches", fields: [awayTeamId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  status                  MatchStatus       @default(SCHEDULED)
  homeScore               Int?
  awayScore               Int?
  winnerTeamId            String?
  standingsUpdateRequired Boolean           @default(false)
  playerStats             MatchPlayerStat[]
  playedAt                DateTime?
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@index([seasonId, round])
  @@index([date])
  @@index([homeTeamId])
  @@index([awayTeamId])
}

model MatchPlayerStat {
  id        String   @id @default(cuid())
  matchId   String
  match     Match    @relation(fields: [matchId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  points    Int      @default(0)
  rebounds  Int      @default(0)
  assists   Int      @default(0)
  steals    Int      @default(0)
  blocks    Int      @default(0)
  minutes   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
  @@index([teamId])
}

model Standing {
  id            String   @id @default(cuid())
  seasonId      String
  season        Season   @relation(fields: [seasonId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  teamId        String
  team          Team     @relation(fields: [teamId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  position      Int      @default(0)
  wins          Int      @default(0)
  losses        Int      @default(0)
  pointsFor     Int      @default(0)
  pointsAgainst Int      @default(0)
  pointDiff     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([seasonId, teamId])
  @@index([seasonId])
  @@index([seasonId, position])
  @@index([teamId])
}

model CareerSave {
  id              String   @id @default(cuid())
  saveName        String   @db.VarChar(120)
  selectedTeamId  String
  selectedTeam    Team     @relation(fields: [selectedTeamId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  currentSeasonId String
  currentSeason   Season   @relation(fields: [currentSeasonId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  currentDate     DateTime @default(now())
  currentRound    Int      @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([selectedTeamId])
  @@index([currentSeasonId])
  @@index([updatedAt])
}
